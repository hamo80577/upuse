{
  "name": "upuse",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c auto \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace apps/server run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/server run build && npm --workspace apps/web run build",
    "start": "node scripts/start-production.mjs",
    "test:ops": "node --test scripts/start-production.test.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
